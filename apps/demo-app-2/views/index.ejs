<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= config.appName %> - SSO Demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --app-color: <%= config.appColor %>;
        }
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }
        .navbar {
            background: var(--app-color) !important;
        }
        .hero-section {
            padding: 100px 0;
            text-align: center;
        }
        .btn-primary {
            background-color: var(--app-color);
            border-color: var(--app-color);
        }
        .btn-primary:hover {
            background-color: color-mix(in srgb, var(--app-color) 80%, black);
            border-color: color-mix(in srgb, var(--app-color) 80%, black);
        }
        .feature-card {
            transition: transform 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .sso-badge {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: rgba(0,0,0,0.8);
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-shield-lock me-2"></i>
                <%= config.appName %>
            </a>
            <div class="navbar-nav ms-auto">
                <% if (isAuthenticated) { %>
                    <span class="navbar-text text-white me-3">
                        <i class="bi bi-person-circle me-1"></i>
                        Hola, <%= user.displayName || user.username %>
                    </span>
                    <a class="btn btn-outline-light btn-sm" href="/dashboard">Dashboard</a>
                    <a class="btn btn-light btn-sm ms-2" href="/logout">
                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                    </a>
                <% } else { %>
                    <a class="btn btn-light" href="/login">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Iniciar Sesión con SSO
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="hero-section">
            <h1 class="display-4 mb-4">
                <i class="bi bi-shield-check text-success me-3"></i>
                Bienvenido a <%= config.appName %>
            </h1>
            <p class="lead text-muted mb-5">
                Demostración de Single Sign-On (SSO) y Autenticación Multi-Factor (MFA)
            </p>
            
            <% if (!isAuthenticated) { %>
                <a href="/login" class="btn btn-primary btn-lg px-5 py-3">
                    <i class="bi bi-key me-2"></i>
                    Iniciar Sesión con Keycloak
                </a>
                <p class="mt-3 text-muted">
                    <small>Serás redirigido al Identity Provider (Keycloak) para autenticarte</small>
                </p>
            <% } else { %>
                <div class="alert alert-success d-inline-block">
                    <i class="bi bi-check-circle me-2"></i>
                    ¡Autenticado exitosamente via SSO!
                </div>
                <div class="mt-4">
                    <a href="/dashboard" class="btn btn-primary btn-lg me-2">
                        <i class="bi bi-speedometer2 me-2"></i>
                        Ir al Dashboard
                    </a>
                    <a href="/tokens" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-code-slash me-2"></i>
                        Ver Tokens
                    </a>
                </div>
            <% } %>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card feature-card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-key-fill text-primary" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">Single Sign-On</h5>
                        <p class="card-text text-muted">
                            Un solo inicio de sesión para acceder a múltiples aplicaciones.
                            Autentícate una vez y accede a todo.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-shield-lock-fill text-success" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">Multi-Factor Auth</h5>
                        <p class="card-text text-muted">
                            Capa adicional de seguridad con TOTP.
                            Usa Google Authenticator o similar.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card feature-card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <i class="bi bi-diagram-3-fill text-warning" style="font-size: 3rem;"></i>
                        <h5 class="card-title mt-3">OpenID Connect</h5>
                        <p class="card-text text-muted">
                            Protocolo estándar de la industria.
                            Tokens JWT seguros y verificables.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-5 shadow">
            <div class="card-header bg-dark text-white">
                <i class="bi bi-info-circle me-2"></i>
                Información del Lab
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Componentes:</h6>
                        <ul class="list-unstyled">
                            <li><i class="bi bi-check text-success me-2"></i>Keycloak (Identity Provider)</li>
                            <li><i class="bi bi-check text-success me-2"></i>Portal de Empleados (Puerto 3001)</li>
                            <li><i class="bi bi-check text-success me-2"></i>Sistema de Reportes (Puerto 3002)</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>URLs:</h6>
                        <ul class="list-unstyled">
                            <li><code>http://localhost:8080</code> - Keycloak Admin</li>
                            <li><code>http://localhost:3001</code> - App 1</li>
                            <li><code>http://localhost:3002</code> - App 2</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sso-badge">
        <i class="bi bi-broadcast me-2"></i>
        SSO Demo Lab
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
